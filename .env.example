# OPNsense WOL — Environment Variables
# Copy this to .env and fill in your values

# OPNsense Connection
OPNSENSE_URL=https://opnsense.lan
OPNSENSE_API_KEY=your_api_key
OPNSENSE_API_SECRET=your_api_secret

# Server
PORT=3000
VERIFY_SSL=false

# Demo Mode (set to "true" to run with mock data — no OPNsense needed)
# DEMO_MODE=true
